# ─── DB ───────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root1234
MYSQL_DATABASE=crawlerdb
MYSQL_USER=crawler
MYSQL_PASSWORD=crawler1234

# ─── Crawler ──────────────────────────────────────
CRAWL_INTERVAL_SEC=3600   # 크롤 주기(초). 개발 시 60으로 낮춰서 테스트

# ─── Backend ──────────────────────────────────────
# social_crawl_account loginId / loginPw AES-256-GCM 암호화 키
# 운영 환경에서는 반드시 32자 이상의 무작위 문자열로 교체할 것
ENCRYPTION_SECRET_KEY=ChangeThisSecretKeyInProduction!!

# ─── Frontend ─────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080
